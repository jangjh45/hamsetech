# =============================================
# hamsetech 환경변수 설정
# 사용법: cp .env.example .env 후 값을 채워주세요
# .env 파일은 절대 Git에 커밋하지 마세요!
# =============================================

# ── Docker (프로덕션) ───────────────────────────
# NAS 등에서 호스트 80이 이미 사용 중이면 기본 8080 사용
# FRONTEND_HOST_PORT=8080

# ── Database ──────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=hamsetech
DB_USERNAME=hamsetech
DB_PASSWORD=hamsetech

# ── JWT ───────────────────────────────────────
# 최소 32자 이상의 랜덤 문자열을 사용하세요
JWT_SECRET=ChangeThisToAVeryLongAndStrongRandomSecretKey1234567890

# ── Admin 계정 (초기 설정용) ──────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234

# ── OAuth2 (사용 시 주석 해제) ────────────────
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
